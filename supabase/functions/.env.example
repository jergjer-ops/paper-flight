# Copy to .env.local for local development. Never commit the real bot token.
# Set production values in Supabase Edge Function Secrets.
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_EXPECTED_USERNAME=replace-with-exact-bot-username-without-at
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-32-to-64-character-secret
TELEGRAM_SETUP_SECRET=replace-with-a-different-random-secret
ALLOWED_ORIGINS=https://jergjer-ops.github.io
